{
  "manifest_version": 3,
  "name": "YT Focus Control",
  "version": "1.0",
  "permissions": ["storage", "tabs", "alarms"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}